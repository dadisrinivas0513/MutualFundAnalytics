import pandas as pd
import matplotlib.pyplot as plt

df = pd.read_csv(
    "data/raw/05_category_inflows.csv"
)

latest = (
    df.groupby("category")
    ["net_inflow_crore"]
    .sum()
    .sort_values(ascending=False)
)

latest.plot(
    kind="bar",
    figsize=(12,6)
)

plt.title("Category Inflows")

plt.tight_layout()

plt.savefig(
    "reports/charts/category_inflows.png"
)